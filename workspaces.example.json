{
  "config_version": "2.0.0",
  "gateway": {
    "listen": "0.0.0.0",
    "port": 6767,
    "base_url": "http://ip-or-fqdn-gatewayserver:6767",
    "api_rate_limit_per_second": 8,
    "api_retry_attempts": 3,
    "device_cache_ttl_seconds": 240,
    "site_cache_ttl_seconds": 300,
    "version_check_enabled": true,
    "version_check_ref": "main",
    "access_log": false
  },
  "sync": {
    "interval_seconds": 1800
  },
  "zabbix": {
    "api_url": "https://zabbix.example.com/api_jsonrpc.php",
    "api_token": "zabbix-api-token",
    "unmapped_host_group": "HPE Aruba Central/Unmapped",
    "gateway_host": "HPE Aruba Central Gateway",
    "auto_import_template": true,
    "managed_tag": {
      "tag": "hpe-aruba-central-ng",
      "value": ""
    },
    "host_tags": {
      "ap": "WiFi",
      "switch": "Switch",
      "gateway": "Gateway"
    },
    "templates": {
      "service": "HPE Aruba Central NG - Gateway",
      "site": "HPE Aruba Central NG - Site",
      "ap": "HPE Aruba Central NG - DeviceType AP",
      "switch": "HPE Aruba Central NG - DeviceType Switch",
      "gateway": "HPE Aruba Central NG - DeviceType Gateway"
    }
  },
  "workspaces": [
    {
      "name": "WORKSPACE MSP",
      "mode": "msp",
      "workspace_id": "workspace-id",
      "client_id": "client-id",
      "client_secret": "client-secret",
      "central_base_url": "https://de2.api.central.arubanetworks.com",
      "discover_devices": "all",
      "tenant_allowlist": [],
      "tenant_mappings": [
        {
          "tenant_name": "Central tenant name",
          "host_prefix": "CUSTOMER",
          "discover_devices": ["ap", "switch"]
        }
      ]
    },
    {
      "name": "WORKSPACE STANDALONE",
      "mode": "standalone",
      "workspace_id": "workspace-id",
      "client_id": "client-id",
      "client_secret": "client-secret",
      "central_base_url": "https://de2.api.central.arubanetworks.com",
      "discover_devices": ["ap", "switch", "gateway"],
      "mapping": {
        "host_prefix": "CUSTOMER",
        "discover_devices": "all"
      }
    }
  ]
}
